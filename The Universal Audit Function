CREATE OR REPLACE FUNCTION process_audit_log()
RETURNS TRIGGER AS $$
BEGIN
    -- Only log if it's an UPDATE or DELETE
    -- We record the old and new states as JSON
    INSERT INTO audit_logs (
        table_name,
        record_id,
        action,
        old_value,
        new_value,
        changed_by
    )
    VALUES (
        TG_TABLE_NAME,
        COALESCE(OLD.id, NEW.id),
        TG_OP,
        to_jsonb(OLD),
        to_jsonb(NEW),
        auth.uid() -- Automatically captures the Supabase User ID
    );

    IF (TG_OP = 'DELETE') THEN
        RETURN OLD;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;
